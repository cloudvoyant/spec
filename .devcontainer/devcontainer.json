{
  "name": "mise-lib-template",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers-extra/features/mise:1": {},
  },
  "mounts": [
    // Claude CLI credentials (cross-platform: HOME on Unix, USERPROFILE on Windows)
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "timonwong.shellcheck",
        "foxundermoon.shell-format",
        "hverlin.mise-vscode",
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
      },
    },
  },
  "postCreateCommand": "mise install && mise run install && mise run install-claude-plugins",
  "remoteUser": "vscode",
}
