#!/usr/bin/env bash
#MISE description="Scaffold a new project from this template"
: <<DOCUMENTATION
Scaffolds a new project from this platform

Called by Nedavellir CLI after copying platform files to destination.
Updates project-specific configuration in the destination directory.

Usage:
  mise run scaffold -- --src /path/to/template --dest /path/to/project
  mise run scaffold -- --src /path/to/template --dest /path/to/project --non-interactive
  mise run scaffold -- --src /path/to/template --dest /path/to/project --project myapp
  mise run scaffold  # Uses current directory for both src and dest

Options:
  --src PATH           Path to template source directory (default: project root)
  --dest PATH          Path to destination project directory (default: project root)
  --non-interactive    Skip prompts, use defaults
  --project NAME       Project name (default: destination directory name)
  --keep-claude        Keep .claude/ directory for AI workflows
  --template NAME      Language template to apply: uv, zig (default: agnostic)
DOCUMENTATION

# IMPORTS ----------------------------------------------------------------------
set -euo pipefail

source "$(dirname "$0")/utils"
source "$(dirname "$0")/template-utils"

# Load template name and version from mise.toml / version.txt
unset PROJECT VERSION

if command -v mise >/dev/null 2>&1; then
    eval "$(mise env -s bash 2>/dev/null)" || true
fi
# Fallback: parse mise.toml directly for PROJECT
if [ -z "${PROJECT:-}" ] && [ -f "mise.toml" ]; then
    PROJECT=$(grep '^PROJECT' mise.toml | head -1 | sed 's/PROJECT *= *"\(.*\)"/\1/')
fi
# VERSION from version.txt
VERSION=$(cat version.txt 2>/dev/null | tr -d '[:space:]' || echo "0.1.0")

# CONFIGURATION ----------------------------------------------------------------
# Platform name will be read from source mise.toml PROJECT variable

# Track if we've started making changes (for cleanup on error)
SCAFFOLD_STARTED=false
BACKUP_DIR=""

# Cleanup function for failed scaffolds
cleanup_on_error() {
    local exit_code=$?
    if [ "$exit_code" -ne 0 ] && [ "$SCAFFOLD_STARTED" = true ]; then
        log_error "Scaffolding failed. Restoring original directory"

        if [ -n "$BACKUP_DIR" ] && [ -d "$BACKUP_DIR" ]; then
            # Ensure destination and all contents are writable for cleanup
            chmod u+w "$DEST_DIR" 2>/dev/null || true
            chmod -R u+w "$DEST_DIR" 2>/dev/null || true

            # Remove all files from destination (except .tmp backup)
            find "$DEST_DIR" -mindepth 1 -maxdepth 1 ! -name '.tmp' -exec rm -rf {} + 2>/dev/null || true

            # Restore entire directory from backup
            rsync -a "$BACKUP_DIR/" "$DEST_DIR/"

            # Remove backup
            rm -rf "$BACKUP_DIR"
        fi

        log_error "Destination directory has been restored to its original state"
    fi
}

trap cleanup_on_error EXIT

# PARSE OPTIONS ----------------------------------------------------------------
NON_INTERACTIVE=false
KEEP_CLAUDE=false
PROJECT_NAME=""
TEMPLATE=""

# Default to project root directory
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SRC_DIR="$PROJECT_ROOT"
DEST_DIR="$PROJECT_ROOT"
TEMPLATES_DIR="$(get_templates_dir)"

while [[ $# -gt 0 ]]; do
    case $1 in
        --src)
            SRC_DIR="$2"
            shift 2
            ;;
        --dest)
            DEST_DIR="$2"
            shift 2
            ;;
        --non-interactive)
            NON_INTERACTIVE=true
            shift
            ;;
        --project)
            PROJECT_NAME="$2"
            shift 2
            ;;
        --keep-claude)
            KEEP_CLAUDE=true
            shift
            ;;
        --template)
            TEMPLATE="$2"
            shift 2
            ;;
        *)
            log_error "Unknown option: $1"
            exit 1
            ;;
    esac
done

# Discover valid templates dynamically from templates/ subdirectories
VALID_TEMPLATES=()
while IFS= read -r t; do VALID_TEMPLATES+=("$t"); done < <(list_templates)

if [[ -n "$TEMPLATE" ]]; then
    valid=false
    for t in "${VALID_TEMPLATES[@]}"; do
        [[ "$TEMPLATE" == "$t" ]] && valid=true && break
    done
    if ! $valid; then
        log_error "Unknown template '$TEMPLATE'. Valid options: ${VALID_TEMPLATES[*]}"
        exit 1
    fi
fi

# VALIDATION -------------------------------------------------------------------
# Convert to absolute paths
SRC_DIR=$(cd "$SRC_DIR" 2>/dev/null && pwd) || {
    log_error "Source directory does not exist: $SRC_DIR"
    exit 1
}

DEST_DIR=$(cd "$DEST_DIR" 2>/dev/null && pwd) || {
    log_error "Destination directory does not exist: $DEST_DIR"
    exit 1
}

validate_project_name() {
    local name=$1
    # Allow alphanumeric, hyphens, underscores
    if [[ ! "$name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        return 1
    fi
    return 0
}

# Convert string to word array (split on _ - or camelCase boundaries)
string_to_words() {
    local input=$1
    # First, insert underscores before capital letters (for camelCase/PascalCase)
    input=$(echo "$input" | sed 's/\([A-Z]\)/_\1/g' | sed 's/^_//')
    # Replace hyphens with underscores
    input=$(echo "$input" | tr '-' '_')
    # Convert to lowercase and split on underscores, output one word per line
    echo "$input" | tr '[:upper:]' '[:lower:]' | tr '_' '\n' | grep -v '^$'
}

# Convert word array to snake_case
words_to_snake() {
    echo "$1" | tr '\n' '_' | sed 's/_$//'
}

# Convert word array to kebab-case
words_to_kebab() {
    echo "$1" | tr '\n' '-' | sed 's/-$//'
}

# Convert word array to PascalCase
words_to_pascal() {
    echo "$1" | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1' | tr -d '\n'
}

# Convert word array to camelCase
words_to_camel() {
    local words="$1"
    local first=$(echo "$words" | head -1)
    local rest=$(echo "$words" | tail -n +2)
    if [ -n "$rest" ]; then
        echo -n "$first"
        echo "$rest" | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) tolower(substr($i,2))}1' | tr -d '\n'
    else
        echo -n "$first"
    fi
}

# Convert word array to flatcase (no separators)
words_to_flat() {
    echo "$1" | tr -d '\n'
}

# Apply language template overlay to destination
apply_template() {
    local template="$1"
    local dest="$2"
    local template_src="$TEMPLATES_DIR/$template"

    if [[ ! -d "$template_src" ]]; then
        log_error "Template directory not found: $template_src"
        exit 1
    fi

    log_info "Applying $template template overlay..."

    # Overlay template files (exclude meta files not for scaffolded projects)
    rsync -a \
        --exclude='CLAUDE.md.append' \
        --exclude='README.md' \
        --exclude='node_modules' \
        "$template_src/" "$dest/"

    # Ensure .mise-tasks/ scripts are executable
    if [[ -d "$dest/.mise-tasks" ]]; then
        chmod +x "$dest/.mise-tasks/"* 2>/dev/null || true
    fi

    # Re-run name substitutions on newly overlaid files
    # (the bulk sed pass ran before this overlay)
    find "$dest" -type f ! -path "*/.git/*" ! -path "$dest/.tmp/*" 2>/dev/null | while IFS= read -r file; do
        sed_inplace "s/${TEMPLATE_PASCAL}/${PROJECT_PASCAL}/g" "$file" || true
        sed_inplace "s/${TEMPLATE_CAMEL}/${PROJECT_CAMEL}/g"   "$file" || true
        sed_inplace "s/${TEMPLATE_SNAKE}/${PROJECT_SNAKE}/g"   "$file" || true
        sed_inplace "s/${TEMPLATE_KEBAB}/${PROJECT_KEBAB}/g"   "$file" || true
        sed_inplace "s/${TEMPLATE_FLAT}/${PROJECT_FLAT}/g"     "$file" || true
    done

    # Rename mise_lib_template/ directory inside src/ if template created it
    # (directory names are not changed by sed — requires explicit mv)
    local src_pkg_dir="$dest/src/mise_lib_template"
    if [[ -d "$src_pkg_dir" ]]; then
        mv "$src_pkg_dir" "$dest/src/$PROJECT_SNAKE"
        log_info "Renamed src/mise_lib_template/ → src/$PROJECT_SNAKE/"
    fi

    log_success "$template template applied"
}

# Append CLAUDE.md.append from template to destination CLAUDE.md
append_claude_md() {
    local template="$1"
    local dest="$2"
    local append_file="$TEMPLATES_DIR/$template/CLAUDE.md.append"
    local dest_claude="$dest/CLAUDE.md"

    if [[ -f "$append_file" ]] && [[ -f "$dest_claude" ]]; then
        log_info "Appending $template conventions to CLAUDE.md..."
        printf '\n---\n' >> "$dest_claude"
        cat "$append_file" >> "$dest_claude"
        log_success "CLAUDE.md updated with $template conventions"
    fi
}

# Remove agnostic placeholder files when a template is applied
cleanup_agnostic_placeholders() {
    local dest="$1"
    log_info "Removing agnostic placeholder files..."

    # Remove language-agnostic sample code (replaced by real template source)
    rm -f "$dest/src/sample-code.txt"

    # Remove src/.gitkeep if real source files now exist
    if find "$dest/src" -type f ! -name '.gitkeep' | grep -q .; then
        rm -f "$dest/src/.gitkeep"
    fi

    log_info "Agnostic placeholders removed"
}

# Update TEMPLATE tracking var in output mise.toml to match chosen template
update_template_tracking() {
    local template="$1"
    local dest="$2"
    local mise_toml="$dest/mise.toml"
    local template_pkg="mise-${template}-template"

    if [[ -f "$mise_toml" ]]; then
        if grep -q "^TEMPLATE[[:space:]]*=" "$mise_toml"; then
            # TEMPLATE line already exists (injected by base awk) — update it
            sed_inplace "s|^TEMPLATE[[:space:]]*= *\".*\"|TEMPLATE         = \"$template_pkg\"|" "$mise_toml"
        else
            # Template overlay replaced mise.toml with one that has no TEMPLATE key — inject after PROJECT line
            awk -v pkg="$template_pkg" '
                /^PROJECT[[:space:]]*=/ { print; print "TEMPLATE         = \"" pkg "\""; next }
                { print }
            ' "$mise_toml" > "$mise_toml.tmp" && mv "$mise_toml.tmp" "$mise_toml"
        fi
        log_info "TEMPLATE set to $template_pkg"
    fi
}

# GET TEMPLATE NAME AND VERSION -----------------------------------------------
log_info "Detecting template name and version"

# Use environment variables from sourced .envrc
TEMPLATE_NAME="${PROJECT:-}"
TEMPLATE_VERSION="${VERSION:-}"

# Validate we have the required values
if [ -z "$TEMPLATE_NAME" ]; then
    log_error "Could not determine template name (PROJECT not set in mise.toml)"
    log_error "Please ensure mise.toml exists and contains: PROJECT = \"<template-name>\""
    exit 1
fi

if [ -z "$TEMPLATE_VERSION" ]; then
    log_error "Could not determine template version (VERSION not found)"
    log_error "Please ensure version.txt exists with a version number"
    exit 1
fi

log_info "Template: $TEMPLATE_NAME v$TEMPLATE_VERSION"

# DEFAULT PROJECT NAME ---------------------------------------------------------
DEFAULT_PROJECT=$(basename "$DEST_DIR")

# INTERACTIVE PROMPTS ----------------------------------------------------------
if [ "$NON_INTERACTIVE" = false ]; then
    log_info "Scaffolding new project from $TEMPLATE_NAME platform"
    echo ""

    # Prompt for project name
    while true; do
        read -p "Project name [$DEFAULT_PROJECT]: " input_name
        PROJECT_NAME="${input_name:-$DEFAULT_PROJECT}"

        if validate_project_name "$PROJECT_NAME"; then
            break
        else
            log_error "Invalid project name. Use only letters, numbers, hyphens, and underscores."
        fi
    done

    # Prompt for GCP registry configuration
    read -p "Configure GCP Artifact Registry? (y/N): " configure_gcp
    if [[ "$configure_gcp" =~ ^[Yy]$ ]]; then
        read -p "GCP Project ID: " gcp_project_id
        read -p "GCP Region [us-east1]: " gcp_region
        gcp_region="${gcp_region:-us-east1}"
        read -p "GCP Repository: " gcp_repository
        CONFIGURE_GCP=true
    else
        CONFIGURE_GCP=false
    fi

    # Prompt for .claude/ directory
    read -p "Keep .claude/ directory for AI workflows? (y/N): " keep_claude_input
    if [[ "$keep_claude_input" =~ ^[Yy]$ ]]; then
        KEEP_CLAUDE=true
    fi

    # Prompt for install.sh binary distribution script
    read -p "Create install.sh for binary distribution? (y/N): " configure_install
    if [[ "$configure_install" =~ ^[Yy]$ ]]; then
        CONFIGURE_INSTALL=true
    else
        CONFIGURE_INSTALL=false
    fi

    # Prompt for language template — menu built dynamically from templates/ subdirs
    if [[ -z "$TEMPLATE" ]]; then
        echo ""
        echo "Select a language template:"
        echo "  0) agnostic  — language-neutral starter (fill in your own tasks)"
        i=1
        for t in "${VALID_TEMPLATES[@]}"; do
            printf "  %d) %s\n" "$i" "$t"
            (( i++ ))
        done
        echo ""
        read -rp "Template [0-${#VALID_TEMPLATES[@]}] (default: 0 agnostic): " template_choice
        if [[ "$template_choice" =~ ^[1-9][0-9]*$ ]] && (( template_choice >= 1 && template_choice <= ${#VALID_TEMPLATES[@]} )); then
            TEMPLATE="${VALID_TEMPLATES[$((template_choice - 1))]}"
        else
            TEMPLATE=""  # agnostic
        fi
    fi

    echo ""
else
    # Non-interactive mode: use defaults
    PROJECT_NAME="${PROJECT_NAME:-$DEFAULT_PROJECT}"
    CONFIGURE_GCP=false
    CONFIGURE_INSTALL=false

    if ! validate_project_name "$PROJECT_NAME"; then
        log_error "Invalid project name: $PROJECT_NAME"
        exit 1
    fi

    log_info "Non-interactive mode: project=$PROJECT_NAME"
    if [[ -n "$TEMPLATE" ]]; then
        log_info "Non-interactive mode: template=$TEMPLATE"
    else
        log_info "Non-interactive mode: no language template (agnostic)"
    fi
fi

# BACKUP DESTINATION DIRECTORY ------------------------------------------------
log_info "Creating backup of destination directory"

BACKUP_DIR="$DEST_DIR/.tmp/.scaffold-backup"
mkdir -p "$BACKUP_DIR"

# Backup entire destination directory (excluding .tmp to avoid recursion)
rsync -a \
    --exclude='.tmp' \
    --exclude='node_modules' \
    "$DEST_DIR/" "$BACKUP_DIR/"

# Mark that we've started making changes
SCAFFOLD_STARTED=true

log_success "Backup created"

# COPY PLATFORM FILES TO DESTINATION -------------------------------------------
log_info "Copying platform files to destination"

# Copy all files from source to destination
# Exclude: .git, .tmp, test/, docs/migrations/, docs/decisions/, CHANGELOG.md, RELEASE_NOTES.md
rsync -a \
    --exclude='.git' \
    --exclude='.tmp' \
    --exclude='node_modules' \
    --exclude='test/' \
    --exclude='templates/' \
    --exclude='docs/migrations/' \
    --exclude='docs/decisions/' \
    --exclude='CHANGELOG.md' \
    --exclude='RELEASE_NOTES.md' \
    "$SRC_DIR/" "$DEST_DIR/"

log_success "Platform files copied"

# REPLACE TEMPLATE NAME WITH PROJECT NAME IN ALL VARIANTS ---------------------
log_info "Replacing template name with project name"

# Generate all variants of template name and project name
TEMPLATE_WORDS=$(string_to_words "$TEMPLATE_NAME")
PROJECT_WORDS=$(string_to_words "$PROJECT_NAME")

# Template name variants
TEMPLATE_SNAKE=$(words_to_snake "$TEMPLATE_WORDS")
TEMPLATE_KEBAB=$(words_to_kebab "$TEMPLATE_WORDS")
TEMPLATE_PASCAL=$(words_to_pascal "$TEMPLATE_WORDS")
TEMPLATE_CAMEL=$(words_to_camel "$TEMPLATE_WORDS")
TEMPLATE_FLAT=$(words_to_flat "$TEMPLATE_WORDS")

# Project name variants
PROJECT_SNAKE=$(words_to_snake "$PROJECT_WORDS")
PROJECT_KEBAB=$(words_to_kebab "$PROJECT_WORDS")
PROJECT_PASCAL=$(words_to_pascal "$PROJECT_WORDS")
PROJECT_CAMEL=$(words_to_camel "$PROJECT_WORDS")
PROJECT_FLAT=$(words_to_flat "$PROJECT_WORDS")

# Replace in all text files (excluding binary files and .git)
find "$DEST_DIR" -type f ! -path "*/.git/*" ! -path "$DEST_DIR/.tmp/*" 2>/dev/null | while IFS= read -r file; do
    # Replace all variants (order matters: longer strings first to avoid partial replacements)
    sed_inplace "s/${TEMPLATE_PASCAL}/${PROJECT_PASCAL}/g" "$file" || true
    sed_inplace "s/${TEMPLATE_CAMEL}/${PROJECT_CAMEL}/g" "$file" || true
    sed_inplace "s/${TEMPLATE_SNAKE}/${PROJECT_SNAKE}/g" "$file" || true
    sed_inplace "s/${TEMPLATE_KEBAB}/${PROJECT_KEBAB}/g" "$file" || true
    sed_inplace "s/${TEMPLATE_FLAT}/${PROJECT_FLAT}/g" "$file" || true
done

log_success "Replaced template name with project name"

# UPDATE mise.toml ------------------------------------------------------------
log_info "Configuring mise.toml"

MISE_TOML="$DEST_DIR/mise.toml"

if [ ! -f "$MISE_TOML" ]; then
    log_error "mise.toml not found in destination directory"
    exit 1
fi

# Create version.txt with initial version
echo "0.1.0" > "$DEST_DIR/version.txt"

# Configure GCP if requested (PROJECT name already replaced by bulk substitution above)
if [ "$CONFIGURE_GCP" = true ]; then
    sed_inplace "s/GCP_REGISTRY_PROJECT_ID *= *\"[^\"]*\"/GCP_REGISTRY_PROJECT_ID = \"$gcp_project_id\"/" "$MISE_TOML"
    sed_inplace "s/GCP_REGISTRY_REGION *= *\"[^\"]*\"/GCP_REGISTRY_REGION = \"$gcp_region\"/" "$MISE_TOML"
    sed_inplace "s/GCP_REGISTRY_NAME *= *\"[^\"]*\"/GCP_REGISTRY_NAME = \"$gcp_repository\"/" "$MISE_TOML"
    log_success "GCP registry configured in mise.toml"
fi

# Add TEMPLATE tracking vars to [env] section if not already present
if ! grep -q '^TEMPLATE' "$MISE_TOML"; then
    awk -v template="$TEMPLATE_NAME" -v version="$TEMPLATE_VERSION" '
    /^GCP_REGISTRY_NAME/ {
        print $0
        print "TEMPLATE         = \"" template "\""
        print "TEMPLATE_VERSION = \"" version "\""
        next
    }
    { print }
    ' "$MISE_TOML" > "$MISE_TOML.tmp" && mv "$MISE_TOML.tmp" "$MISE_TOML"
fi

log_success "Configured mise.toml"

# APPLY LANGUAGE TEMPLATE OVERLAY ----------------------------------------
if [[ -n "$TEMPLATE" ]]; then
    apply_template "$TEMPLATE" "$DEST_DIR"
    cleanup_agnostic_placeholders "$DEST_DIR"
    update_template_tracking "$TEMPLATE" "$DEST_DIR"
fi

# CLEAN UP .CLAUDE/ DIRECTORY --------------------------------------------------
if [ "$KEEP_CLAUDE" = false ]; then
    log_info "Removing .claude/ directory"
    rm -rf "$DEST_DIR/.claude"
    log_success "Removed .claude/ directory"
else
    log_info "Configuring .claude/ directory for client repo"
    # Remove all commands except upgrade.md and README.md
    find "$DEST_DIR/.claude/commands" -type f -name "*.md" ! -name "upgrade.md" ! -name "README.md" -delete 2>/dev/null || true

    # Update README.md to remove /adapt reference (template-only command)
    README_FILE="$DEST_DIR/.claude/commands/README.md"
    if [ -f "$README_FILE" ]; then
        # Remove the line mentioning /adapt from the Template Commands section
        sed_inplace '/^- `\/adapt`.*template-only.*$/d' "$README_FILE"
    fi

    log_success "Configured .claude/ with /upgrade command only"
fi

# CLEAN UP TEMPLATE FILES ------------------------------------------------------
log_info "Cleaning template files"

# Remove template section from mise.toml
MISE_TOML="$DEST_DIR/mise.toml"
if [ -f "$MISE_TOML" ]; then
    # Remove everything from "# TEMPLATE" comment to end of file
    sed_inplace '/^# TEMPLATE$/,$ {/^# TEMPLATE$/d; d;}' "$MISE_TOML"
fi

# Remove template-only .mise-tasks scripts — not needed in scaffolded projects
rm -f "$DEST_DIR/.mise-tasks/template-utils"
rm -f "$DEST_DIR/.mise-tasks/publish-templates"
rm -f "$DEST_DIR/.mise-tasks/publish-templates-rc"
log_info "Removed template-only scripts from scaffolded project"

# Strip template-only steps/jobs from CI workflows
CI_YML="$DEST_DIR/.github/workflows/ci.yml"
if [ -f "$CI_YML" ]; then
    # Remove "Run template tests" step (test-template) and collapse extra blank line
    awk '/- name: Run template tests/{skip=2; next} skip>0{skip--; next} {print}' "$CI_YML" | \
        awk 'prev=="" && /^$/{next} {prev=$0; print}' > "$CI_YML.tmp" && mv "$CI_YML.tmp" "$CI_YML"
    # Rewrite publish-rc job to call project's own publish-rc task (not template-specific)
    sed_inplace 's/mise run publish-templates-rc/mise run publish-rc/' "$CI_YML"
    sed_inplace 's/Publish RC template packages/Publish RC package/' "$CI_YML"
    sed_inplace 's/TEST_PYPI_TOKEN/PYPI_TOKEN/' "$CI_YML"
fi

RELEASE_YML="$DEST_DIR/.github/workflows/release.yml"
if [ -f "$RELEASE_YML" ]; then
    # Remove "Run template tests" step (test-template)
    awk '/- name: Run template tests/{skip=2; next} skip>0{skip--; next} {print}' "$RELEASE_YML" > "$RELEASE_YML.tmp" && mv "$RELEASE_YML.tmp" "$RELEASE_YML"
    # Remove "Publish template packages" step (name + if + run + env block = ~5 lines)
    awk '/- name: Publish template packages/{skip=5; next} skip>0{skip--; next} {print}' "$RELEASE_YML" > "$RELEASE_YML.tmp" && mv "$RELEASE_YML.tmp" "$RELEASE_YML"
fi

# Remove template-only sections from CLAUDE.md (test/bats section is template-specific)
CLAUDE_MD="$DEST_DIR/CLAUDE.md"
if [ -f "$CLAUDE_MD" ]; then
    # Remove from <!-- @context: test, bats --> through the closing --- separator
    awk '
    /<!-- @context: test, bats -->/ { skip=1 }
    skip && /^---$/ { skip=0; next }
    !skip { print }
    ' "$CLAUDE_MD" > "$CLAUDE_MD.tmp" && mv "$CLAUDE_MD.tmp" "$CLAUDE_MD"
    log_info "Removed template-only sections from CLAUDE.md"
fi

# APPEND TEMPLATE CLAUDE.md CONTENT ----------------------------------------
if [[ -n "$TEMPLATE" ]]; then
    append_claude_md "$TEMPLATE" "$DEST_DIR"
fi

# PROCESS DOCUMENTATION TEMPLATES ----------------------------------------------
log_info "Processing documentation templates"

TEMPLATES_PROCESSED=0

# Find and process all *.template.md files
find "$DEST_DIR" -type f -name "*.template.md" ! -path "*/.git/*" ! -path "$DEST_DIR/.tmp/*" 2>/dev/null | while IFS= read -r template_file; do
    # Get output filename (remove .template extension)
    output_file="${template_file%.template.md}.md"

    # Substitute variables
    sed "s/{{PROJECT_NAME}}/$PROJECT_NAME/g; \
         s/{{TEMPLATE_NAME}}/$TEMPLATE_NAME/g; \
         s/{{TEMPLATE_VERSION}}/$TEMPLATE_VERSION/g" \
        "$template_file" > "$output_file"

    # Remove template file
    rm "$template_file"

    TEMPLATES_PROCESSED=$((TEMPLATES_PROCESSED + 1))
done

if [ $TEMPLATES_PROCESSED -gt 0 ]; then
    log_success "Processed $TEMPLATES_PROCESSED documentation template(s)"
else
    log_info "No documentation templates found"
fi

# PROCESS install.sh TEMPLATE --------------------------------------------------
log_info "Processing install.sh template"

if [ "$CONFIGURE_INSTALL" = true ]; then
    # User wants install.sh - process the template
    if [ -f "$DEST_DIR/install.sh.template" ]; then
        # Get GitHub org from git remote (or use placeholder)
        GITHUB_ORG=$(git -C "$DEST_DIR" remote get-url origin 2>/dev/null | sed -n 's|.*github.com[:/]\([^/]*\)/.*|\1|p' || echo "your-github-org")

        # Process install.sh.template
        sed "s/{{PROJECT_NAME}}/$PROJECT_NAME/g; \
             s/{{GITHUB_ORG}}/$GITHUB_ORG/g" \
            "$DEST_DIR/install.sh.template" > "$DEST_DIR/install.sh"

        # Make executable
        chmod +x "$DEST_DIR/install.sh"

        # Remove template
        rm "$DEST_DIR/install.sh.template"

        log_success "Created install.sh for binary distribution"
    else
        log_warn "install.sh.template not found in destination"
    fi
else
    # User doesn't want install.sh - remove the template
    if [ -f "$DEST_DIR/install.sh.template" ]; then
        rm "$DEST_DIR/install.sh.template"
        log_info "Removed install.sh.template (not needed for this project)"
    fi
fi

# Remove README.template.md (should have been processed to README.md)
if [ -f "$DEST_DIR/README.template.md" ]; then
