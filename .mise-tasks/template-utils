#!/usr/bin/env bash
#MISE hide=true
# Template-development utilities. Sourced by scaffold and other template-only scripts.
# REMOVED from scaffolded projects during scaffold cleanup — do not add runtime helpers here.

# Resolve the templates directory relative to this repo root.
get_templates_dir() {
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    echo "$script_dir/../templates"
}

# List valid template names, discovered from templates/ subdirectories.
# Usage: mapfile -t VALID_TEMPLATES < <(list_templates)
list_templates() {
    local templates_dir
    templates_dir="$(get_templates_dir)"
    find "$templates_dir" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null | sort
}
