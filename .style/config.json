{
  "version": "1.0.0",
  "contextual": true,
  "autoLearn": true,
  "tokenBudget": {
    "max": 1500,
    "warn": 1000,
    "target": 800
  },
  "learning": {
    "enabled": true,
    "confidenceThreshold": 0.75,
    "minObservations": 3,
    "autoApply": false
  },
  "contexts": {
    "build": { "priority": "high", "autoDetect": ["mise.toml", "Makefile"] },
    "shell": { "priority": "high", "autoDetect": [".mise-tasks/*", "*.sh"] },
    "bash": { "priority": "high", "autoDetect": [".mise-tasks/*", "*.sh"] },
    "mise-tasks": { "priority": "high", "autoDetect": [".mise-tasks/*"] },
    "git": { "priority": "critical", "autoDetect": ["git"] },
    "test": { "priority": "medium", "autoDetect": ["*.bats", "test/"] },
    "docs": { "priority": "low", "autoDetect": ["*.md", "docs/"] },
    "tools": { "priority": "medium", "autoDetect": ["mise.toml"] }
  }
}
